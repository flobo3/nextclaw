{
  "name": "@nextclaw/desktop",
  "version": "0.0.140",
  "private": true,
  "description": "NextClaw desktop shell powered by Electron.",
  "author": "NextClaw Team",
  "homepage": "https://github.com/Peiiii/nextclaw",
  "main": "dist/src/main.js",
  "license": "MIT",
  "scripts": {
    "bundle:build": "node scripts/update/services/build-product-bundle.service.mjs",
    "bundle:public-key": "node scripts/update/services/write-bundle-public-key.service.mjs",
    "bundle:public-key:ensure": "node scripts/update/services/ensure-bundle-public-key.service.mjs --output build/update-bundle-public.pem",
    "bundle:release-metadata": "node scripts/update/services/write-release-metadata.service.mjs",
    "bundle:seed": "node scripts/update/services/prepare-seed-bundle.service.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "bundle:manifest": "node scripts/update/services/build-update-manifest.service.mjs",
    "dev": "node scripts/ensure-runtime.mjs && pnpm build:main && NEXTCLAW_DESKTOP_RUNTIME_SCRIPT=../../packages/nextclaw/dist/cli/index.js env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "pnpm build:main",
    "build:main": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json --outDir dist --noEmit false",
    "lint": "eslint \"src/**/*.ts\"",
    "tsc": "tsc -p tsconfig.json --noEmit",
    "pack": "node scripts/ensure-runtime.mjs && pnpm bundle:public-key:ensure && pnpm bundle:seed && pnpm build:main && electron-builder --dir",
    "dist": "node scripts/ensure-runtime.mjs && pnpm bundle:public-key:ensure && pnpm bundle:seed && pnpm build:main && electron-builder",
    "smoke": "pnpm build:main && node scripts/smoke-runtime.mjs",
    "smoke:update": "node scripts/smoke-product-update.mjs",
    "validation:prepare-manual-update": "node scripts/prepare-manual-update-validation.mjs",
    "validation:serve-local-update": "node scripts/run-local-update-server.mjs"
  },
  "dependencies": {
    "@nextclaw/channel-plugin-dingtalk": "workspace:*",
    "@nextclaw/channel-plugin-discord": "workspace:*",
    "@nextclaw/channel-plugin-email": "workspace:*",
    "@nextclaw/channel-plugin-feishu": "workspace:*",
    "@nextclaw/channel-plugin-mochat": "workspace:*",
    "@nextclaw/channel-plugin-qq": "workspace:*",
    "@nextclaw/channel-plugin-slack": "workspace:*",
    "@nextclaw/channel-plugin-telegram": "workspace:*",
    "@nextclaw/channel-plugin-wecom": "workspace:*",
    "@nextclaw/channel-plugin-whatsapp": "workspace:*",
    "@nextclaw/channel-runtime": "workspace:*",
    "@nextclaw/core": "workspace:*",
    "@nextclaw/openclaw-compat": "workspace:*",
    "@nextclaw/server": "workspace:*",
    "jszip": "^3.10.1",
    "nextclaw": "workspace:*"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/node": "^20.17.6",
    "electron": "^32.2.1",
    "electron-builder": "^25.1.8",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "io.nextclaw.desktop",
    "productName": "NextClaw Desktop",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "build/icons/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/update-release-metadata.json",
        "to": "update/update-release-metadata.json"
      },
      {
        "from": "build/update-bundle-public.pem",
        "to": "update/update-bundle-public.pem"
      },
      {
        "from": "build/update/seed-product-bundle.zip",
        "to": "update/seed-product-bundle.zip"
      }
    ],
    "npmRebuild": false,
    "asar": true,
    "afterSign": "./scripts/electron-after-sign.cjs",
    "mac": {
      "icon": "build/icons/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "artifactName": "nextclaw-desktop-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility"
    },
    "deb": {
      "packageName": "nextclaw-desktop",
      "maintainer": "NextClaw Team",
      "priority": "optional",
      "packageCategory": "utility",
      "synopsis": "NextClaw Desktop",
      "description": "NextClaw desktop shell powered by Electron."
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Peiiii",
        "repo": "nextclaw"
      }
    ]
  }
}
