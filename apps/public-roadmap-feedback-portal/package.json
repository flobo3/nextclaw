{
  "name": "@nextclaw/public-roadmap-feedback-portal",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.utils.mjs",
    "dev:client": "vite --config vite.config.ts --host 127.0.0.1 --port 5186 --strictPort",
    "dev:server": "tsx watch --tsconfig tsconfig.backend.json server/index.ts",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "tsc -p tsconfig.backend.json",
    "start": "node dist/server/index.js",
    "lint": "cd ../.. && pnpm exec eslint apps/public-roadmap-feedback-portal --config apps/public-roadmap-feedback-portal/eslint.config.mjs --max-warnings=0",
    "tsc": "tsc -p tsconfig.json && tsc -p tsconfig.backend.json --noEmit && tsc -p tsconfig.worker.json",
    "smoke": "node scripts/smoke.test.mjs",
    "smoke:remote": "PUBLIC_ROADMAP_FEEDBACK_PORTAL_SKIP_LOCAL_SERVER=1 node scripts/smoke.test.mjs",
    "deploy": "pnpm run build && pnpm exec wrangler deploy --config wrangler.toml",
    "db:migrate:local": "wrangler d1 migrations apply PUBLIC_ROADMAP_PORTAL_DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply PUBLIC_ROADMAP_PORTAL_DB --remote"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@tanstack/react-query": "^5.90.21",
    "hono": "^4.11.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@cloudflare/workers-types": "^4.20260218.0",
    "@vitejs/plugin-react": "^6.0.1",
    "playwright": "^1.52.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "wrangler": "^4.45.0"
  }
}
