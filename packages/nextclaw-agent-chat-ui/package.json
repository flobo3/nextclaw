{
  "name": "@nextclaw/agent-chat-ui",
  "version": "0.3.2",
  "private": false,
  "description": "Reusable Nextclaw agent chat UI primitives and default skin.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Peiiii/nextclaw.git",
    "directory": "packages/nextclaw-agent-chat-ui"
  },
  "homepage": "https://github.com/Peiiii/nextclaw/tree/master/packages/nextclaw-agent-chat-ui",
  "keywords": [
    "nextclaw",
    "chat-ui",
    "agent-ui",
    "react",
    "components"
  ],
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts --clean --target es2022 --no-fixedExtension",
    "prepack": "pnpm run build",
    "lint": "cd ../.. && eslint \"packages/nextclaw-agent-chat-ui/src/**/*.{ts,tsx}\" packages/nextclaw-agent-chat-ui/vite.config.ts",
    "test": "vitest run",
    "tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../scripts/ensure-pnpm-publish.mjs"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-tooltip": "^1.1.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.462.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.19.33",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
