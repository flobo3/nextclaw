{
  "name": "@nextclaw/ncp-toolkit",
  "version": "0.5.2",
  "private": false,
  "description": "Toolkit implementations built on top of the NextClaw Communication Protocol.",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts --clean --target es2022 --no-fixedExtension",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "node ../../../scripts/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "@nextclaw/ncp": "workspace:*"
  },
  "devDependencies": {
    "@nextclaw/ncp-agent-runtime": "workspace:*",
    "@types/node": "^20.17.6",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  }
}
