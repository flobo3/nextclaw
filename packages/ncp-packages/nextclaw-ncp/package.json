    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../../scripts/ensure-pnpm-publish.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
