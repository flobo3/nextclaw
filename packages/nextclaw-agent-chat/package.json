{
  "name": "@nextclaw/agent-chat",
  "version": "0.1.9",
  "private": false,
  "description": "Nextclaw agent chat core library.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts --clean --target es2022 --no-fixedExtension",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../scripts/ensure-pnpm-publish.mjs"
  },
  "dependencies": {
    "json-schema": "^0.4.0",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^20.17.6",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
