{
  "name": "@nextclaw/nextclaw-ncp-runtime-codex-sdk",
  "version": "0.1.18",
  "private": false,
  "description": "Optional NCP runtime adapter backed by OpenAI Codex SDK.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --dts --clean --target es2022 --no-fixedExtension --unbundle",
    "prepack": "pnpm run build",
    "lint": "eslint .",
    "tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "node ../../../scripts/release/ensure-pnpm-publish.mjs"
  },
  "files": [
    "dist",
    "codex-sdk-loader.cjs",
    "README.md"
  ],
  "dependencies": {
    "@nextclaw/ncp": "workspace:*",
    "@openai/codex-sdk": "^0.107.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "typescript": "^5.6.3"
  }
}
